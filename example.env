# OpenAI
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_VISION_MODEL=gpt-4.1-mini

# Backend paths (inside container or local runtime)
DATA_DIR=/data
UPLOAD_DIR=/data/uploads

# PostgreSQL connection parts
POSTGRES_DB=vinted_app
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_HOST_PORT=5433

# Optional override. If unset, backend builds DATABASE_URL from POSTGRES_* values.
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/vinted_app
